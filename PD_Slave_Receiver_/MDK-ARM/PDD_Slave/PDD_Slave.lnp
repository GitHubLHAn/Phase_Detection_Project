--cpu Cortex-M3
"pdd_slave\startup_stm32f103xb.o"
"pdd_slave\main.o"
"pdd_slave\stm32f1xx_it.o"
"pdd_slave\stm32f1xx_hal_msp.o"
"pdd_slave\lora.o"
"pdd_slave\stm32f1xx_hal_gpio_ex.o"
"pdd_slave\stm32f1xx_hal_adc.o"
"pdd_slave\stm32f1xx_hal_adc_ex.o"
"pdd_slave\stm32f1xx_hal.o"
"pdd_slave\stm32f1xx_hal_rcc.o"
"pdd_slave\stm32f1xx_hal_rcc_ex.o"
"pdd_slave\stm32f1xx_hal_gpio.o"
"pdd_slave\stm32f1xx_hal_dma.o"
"pdd_slave\stm32f1xx_hal_cortex.o"
"pdd_slave\stm32f1xx_hal_pwr.o"
"pdd_slave\stm32f1xx_hal_flash.o"
"pdd_slave\stm32f1xx_hal_flash_ex.o"
"pdd_slave\stm32f1xx_hal_exti.o"
"pdd_slave\stm32f1xx_hal_spi.o"
"pdd_slave\stm32f1xx_hal_tim.o"
